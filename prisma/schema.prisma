// Woontegra Commerce — Prisma schema
// Site ve firma ayarları tek site modeli; tenant kullanılmaz.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  STAFF
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

enum PageType {
  STANDARD
  LEGAL
  LANDING
}

enum LayoutType {
  HOME
  PAGE
  LANDING
}

enum PageBlockType {
  HERO
  HERO_SLIDER
  TEXT
  TEXT_IMAGE
  IMAGE_BANNER
  PRODUCT_GRID
  PRODUCT_CAROUSEL
  CATEGORY_GRID
  BLOG_GRID
  TRUST_BADGES
  FAQ
  CONTACT_FORM
  BRAND_LOGOS
  TESTIMONIALS
  NEWSLETTER
  CUSTOM_SPACER
  CAMPAIGN
}

enum MenuLocation {
  HEADER
  FOOTER
  MOBILE
}

enum MenuItemType {
  PAGE
  CATEGORY
  PRODUCT
  BLOG
  CUSTOM_URL
}

enum ProductKind {
  SOFTWARE
  PHYSICAL
  SERVICE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  PASSIVE
}

enum ProductAttributeType {
  TEXT
  NUMBER
  SELECT
  COLOR
  BOOLEAN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  WAITING_BANK_TRANSFER
  CASH_ON_DELIVERY
}

enum PaymentMethodType {
  BANK_TRANSFER
  CASH_ON_DELIVERY
  PAYTR
  IYZICO
  EXTERNAL_LINK
}

enum PaymentTransactionStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
}

enum MailLogStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum ContactMessageStatus {
  NEW
  READ
  REPLIED
  CLOSED
}

enum FormSubmissionStatus {
  NEW
  READ
  CLOSED
}

enum ProductReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum CampaignType {
  BANNER
  HERO
  PRODUCT_PROMO
  CATEGORY_PROMO
}

enum NotificationType {
  NEW_ORDER
  NEW_CONTACT_MESSAGE
  NEW_REVIEW
  LOW_STOCK
  PAYMENT_WAITING
  SHIPPING_TRACKING_ENTERED
}

enum ShippingStatus {
  PENDING
  PREPARING
  SHIPPED
  DELIVERED
  RETURNED
}

enum ShippingMethodType {
  FIXED
  FREE_OVER_AMOUNT
}

enum HeaderLogoPosition {
  LEFT
  CENTER
}

enum HeaderMenuPosition {
  LEFT
  CENTER
  RIGHT
}

model Menu {
  id        String       @id @default(cuid())
  name      String
  location  MenuLocation @unique
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  items MenuItem[]
}

model MenuItem {
  id           String       @id @default(cuid())
  menuId       String
  parentId     String?
  label        String
  type         MenuItemType
  targetId     String?
  url          String?
  openInNewTab Boolean      @default(false)
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  menu     Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent   MenuItem?  @relation("MenuItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children MenuItem[] @relation("MenuItemTree")

  @@index([menuId])
  @@index([parentId])
  @@index([sortOrder])
}

model FooterSetting {
  id              String   @id @default("default")
  logoMediaId     String?
  description     String?
  phone           String?
  email           String?
  address         String?
  showNewsletter  Boolean  @default(false)
  copyrightText   String?
  socialLinks     Json     @default("{}")
  paymentIconIds  Json     @default("[]")
  shippingIconIds Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FooterColumn {
  id        String   @id @default(cuid())
  title     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  links FooterLink[]

  @@index([sortOrder])
}

model FooterLink {
  id           String       @id @default(cuid())
  columnId     String
  label        String
  type         MenuItemType
  targetId     String?
  url          String?
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  openInNewTab Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  column FooterColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@index([columnId])
  @@index([sortOrder])
}

model ThemeSetting {
  id                String   @id @default("default")
  activeThemeKey    String   @default("default")
  colorPalette      Json     @default("{}")
  typography        Json     @default("{}")
  layout            Json     @default("{}")
  buttonStyle       Json     @default("{}")
  cardStyle         Json     @default("{}")
  headerStyle       Json     @default("{}")
  productCardStyle  Json     @default("{}")
  borderRadius      String   @default("md")
  shadowLevel       String   @default("sm")
  containerWidth    String   @default("1280px")
  customCss         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model HeaderSetting {
  id                  String              @id @default("default")
  logoPosition        HeaderLogoPosition  @default(LEFT)
  menuPosition        HeaderMenuPosition  @default(CENTER)
  headerHeight        String              @default("3.5rem")
  stickyHeader        Boolean             @default(false)
  showSearch          Boolean             @default(true)
  showAccountIcon     Boolean             @default(true)
  showFavoritesIcon   Boolean             @default(false)
  showCartIcon        Boolean             @default(true)
  topBarEnabled       Boolean             @default(false)
  topBarText          String?
  topBarBackground    String?
  topBarTextColor     String?
  announcementEnabled Boolean             @default(false)
  announcementText    String?
  announcementLink    String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model BlogCategory {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  seoTitle        String?
  seoDescription  String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  posts BlogPost[]

  @@index([isActive])
}

model BlogPost {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  excerpt        String?
  contentHtml    String     @default("")
  coverImageId   String?
  categoryId     String?
  status         PageStatus @default(DRAFT)
  authorName     String?
  readingTime    Int?
  tags           Json       @default("[]")
  seoTitle       String?
  seoDescription String?
  ogImageId      String?
  robotsIndex    Boolean    @default(true)
  publishedAt    DateTime?
  createdById    String?
  updatedById    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  category  BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User?         @relation("BlogPostCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?         @relation("BlogPostUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([categoryId])
  @@index([publishedAt])
}

model Page {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  status          PageStatus @default(DRAFT)
  pageType        PageType   @default(STANDARD)
  excerpt         String?
  contentHtml     String     @default("")
  blocksJson      Json?
  featuredImageId String?
  seoTitle        String?
  seoDescription  String?
  ogImageId       String?
  canonicalUrl    String?
  robotsIndex     Boolean    @default(true)
  publishedAt     DateTime?
  createdById     String?
  updatedById     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  createdBy User? @relation("PageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("PageUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  layouts   PageLayout[]

  @@index([status])
  @@index([pageType])
  @@index([publishedAt])
}

model PageLayout {
  id          String       @id @default(cuid())
  pageId      String?
  layoutType  LayoutType
  name        String
  status      PageStatus   @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  page   Page?       @relation(fields: [pageId], references: [id], onDelete: Cascade)
  blocks PageBlock[]

  @@index([pageId])
  @@index([layoutType])
  @@index([status])
  @@index([publishedAt])
}

model PageBlock {
  id        String        @id @default(cuid())
  layoutId  String
  type      PageBlockType
  title     String?
  settings  Json          @default("{}")
  content   Json          @default("{}")
  sortOrder Int           @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  layout PageLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@index([layoutId])
  @@index([sortOrder])
}

model ProductCategory {
  id              String   @id @default(cuid())
  parentId        String?
  name            String
  slug            String   @unique
  description     String?
  imageId         String?
  bannerImageId   String?
  seoTitle        String?
  seoDescription  String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parent   ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ProductCategory[] @relation("ProductCategoryTree")
  products Product[]

  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
}

model Brand {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logoId          String?
  description     String?
  seoTitle        String?
  seoDescription  String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  products Product[]

  @@index([isActive])
}

model Product {
  id                   String        @id @default(cuid())
  name                 String
  slug                 String        @unique
  sku                  String?       @unique
  barcode              String?
  productKind          ProductKind   @default(PHYSICAL)
  shortDescription     String?
  descriptionHtml      String        @default("")
  categoryId           String?
  brandId              String?
  status               ProductStatus @default(DRAFT)
  basePrice            Decimal?      @db.Decimal(12, 2)
  salePrice            Decimal?      @db.Decimal(12, 2)
  taxRate              Decimal?      @db.Decimal(5, 2)
  stockTrackingEnabled Boolean       @default(false)
  stockQuantity        Int?
  lowStockThreshold    Int?
  mainImageId          String?
  galleryImageIds      Json          @default("[]")
  tags                 Json          @default("[]")
  isFeatured           Boolean       @default(false)
  isNew                Boolean       @default(false)
  isBestSeller         Boolean       @default(false)
  demoUrl              String?
  purchaseUrl          String?
  downloadUrl          String?
  seoTitle             String?
  seoDescription       String?
  ogImageId            String?
  canonicalUrl         String?
  robotsIndex          Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  category ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand    Brand?           @relation(fields: [brandId], references: [id], onDelete: SetNull)
  attributeAssignments ProductAttributeAssignment[]
  variants             ProductVariant[]
  cartItems            CartItem[]
  orderItems           OrderItem[]
  reviews              ProductReview[]

  @@index([status])
  @@index([categoryId])
  @@index([brandId])
  @@index([productKind])
  @@index([isFeatured])
}

model ProductAttribute {
  id              String               @id @default(cuid())
  name            String
  code            String               @unique
  type            ProductAttributeType
  isFilterable    Boolean              @default(false)
  isVariantOption Boolean              @default(false)
  sortOrder       Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  values         ProductAttributeValue[]
  assignments    ProductAttributeAssignment[]
  variantOptions ProductVariantOption[]

  @@index([isFilterable])
  @@index([isVariantOption])
  @@index([sortOrder])
}

model ProductAttributeValue {
  id          String   @id @default(cuid())
  attributeId String
  value       String
  colorHex    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attribute      ProductAttribute             @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  assignments    ProductAttributeAssignment[]
  variantOptions ProductVariantOption[]

  @@unique([attributeId, value])
  @@index([attributeId])
  @@index([sortOrder])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  sku           String?
  barcode       String?
  price         Decimal? @db.Decimal(12, 2)
  salePrice     Decimal? @db.Decimal(12, 2)
  stockQuantity Int?
  imageId       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  options ProductVariantOption[]
  cartItems CartItem[]
  orderItems  OrderItem[]

  @@index([productId])
  @@index([isActive])
}

model ProductVariantOption {
  id               String @id @default(cuid())
  variantId        String
  attributeId      String
  attributeValueId String

  variant        ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute      ProductAttribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeValue ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeId])
  @@index([variantId])
  @@index([attributeId])
  @@index([attributeValueId])
}

model ProductAttributeAssignment {
  id               String   @id @default(cuid())
  productId        String
  attributeId      String
  valueText        String?
  valueNumber      Decimal? @db.Decimal(12, 4)
  valueBoolean     Boolean?
  attributeValueId String?

  product        Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute      ProductAttribute       @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeValue ProductAttributeValue? @relation(fields: [attributeValueId], references: [id], onDelete: SetNull)

  @@unique([productId, attributeId])
  @@index([productId])
  @@index([attributeId])
  @@index([attributeValueId])
}

model Cart {
  id            String   @id @default(cuid())
  sessionId     String?  @unique
  customerId    String?
  couponId      String?
  couponCode    String?
  discountTotal Decimal  @default(0) @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  coupon Coupon?    @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items  CartItem[]

  @@index([customerId])
  @@index([couponId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(12, 2)
  taxRate   Decimal? @db.Decimal(5, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
}

model Order {
  id             String          @id @default(cuid())
  orderNumber    String          @unique
  customerId     String?
  status         OrderStatus     @default(PENDING)
  paymentStatus  PaymentStatus   @default(PENDING)
  shippingStatus ShippingStatus?
  subtotal       Decimal         @db.Decimal(12, 2)
  taxTotal       Decimal         @db.Decimal(12, 2)
  shippingTotal  Decimal         @db.Decimal(12, 2) @default(0)
  discountTotal  Decimal         @db.Decimal(12, 2) @default(0)
  grandTotal     Decimal         @db.Decimal(12, 2)
  customerName   String
  customerEmail  String
  customerPhone  String
  note           String?
  adminNote      String?
  couponId       String?
  couponCode     String?
  paymentMethodId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  items           OrderItem[]
  shipment        Shipment?
  paymentMethod   PaymentMethod?  @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  paymentTransactions PaymentTransaction[]
  reviews         ProductReview[]
  coupon          Coupon?         @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([shippingStatus])
  @@index([paymentMethodId])
  @@index([createdAt])
}

model PaymentMethod {
  id         String            @id @default(cuid())
  type       PaymentMethodType @unique
  name       String
  isActive   Boolean           @default(false)
  isTestMode Boolean           @default(true)
  config     Json              @default("{}")
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  orders Order[]

  @@index([isActive])
}

model PaymentTransaction {
  id                String                   @id @default(cuid())
  orderId           String
  provider          PaymentMethodType
  status            PaymentTransactionStatus @default(PENDING)
  amount            Decimal                  @db.Decimal(12, 2)
  currency          String                   @default("TRY")
  providerReference String?
  rawResponse       Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([provider])
  @@index([status])
}

model ShippingCarrier {
  id                  String   @id @default(cuid())
  name                String
  trackingUrlTemplate String
  logoId              String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  shipments Shipment[]

  @@index([isActive])
}

model ShippingMethod {
  id                    String             @id @default(cuid())
  name                  String
  type                  ShippingMethodType
  price                 Decimal            @db.Decimal(12, 2)
  freeShippingThreshold Decimal?           @db.Decimal(12, 2)
  isActive              Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([isActive])
}

model Shipment {
  id             String         @id @default(cuid())
  orderId        String         @unique
  carrierId      String?
  trackingNumber String?
  trackingUrl    String?
  status         ShippingStatus @default(PENDING)
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier ShippingCarrier? @relation(fields: [carrierId], references: [id], onDelete: SetNull)

  @@index([carrierId])
  @@index([status])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String?
  variantId    String?
  nameSnapshot String
  skuSnapshot  String?
  quantity     Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  taxRate      Decimal? @db.Decimal(5, 2)
  total        Decimal  @db.Decimal(12, 2)

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model SiteSetting {
  id                   String   @id @default("default")
  siteName             String   @default("")
  siteDescription      String   @default("")
  defaultSeoTitle      String   @default("")
  defaultSeoDescription String  @default("")
  domain               String   @default("")
  maintenanceMode      Boolean  @default(false)
  logoMediaId          String?
  faviconMediaId       String?
  ogImageMediaId       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model CompanySetting {
  id             String   @id @default("default")
  companyName    String   @default("")
  tradeName      String   @default("")
  taxNumber      String   @default("")
  taxOffice      String   @default("")
  mersisNumber   String?
  address        String   @default("")
  city           String   @default("")
  district       String   @default("")
  phone          String   @default("")
  whatsapp       String   @default("")
  email          String   @default("")
  supportEmail   String   @default("")
  workingHours   String   @default("")
  currency       String   @default("TRY")
  defaultTaxRate Decimal  @default(20) @db.Decimal(5, 2)
  socialLinks    Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MediaAsset {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  url          String
  storageKey   String   @unique
  folder       String   @default("general")
  altText      String?
  title        String?
  usageType    String?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([folder])
  @@index([mimeType])
  @@index([createdAt])
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs        AuditLog[]
  mediaAssets      MediaAsset[]
  pagesCreated     Page[]     @relation("PageCreatedBy")
  pagesUpdated     Page[]     @relation("PageUpdatedBy")
  blogPostsCreated BlogPost[] @relation("BlogPostCreatedBy")
  blogPostsUpdated BlogPost[] @relation("BlogPostUpdatedBy")

  @@index([email])
  @@index([role])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  module     String
  entityType String?
  entityId   String?
  beforeData Json?
  afterData  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model MailSetting {
  id        String   @id @default("default")
  smtpHost  String   @default("")
  smtpPort  Int      @default(587)
  smtpUser  String   @default("")
  smtpPass  String   @default("")
  fromName  String   @default("")
  fromEmail String   @default("")
  replyTo   String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MailTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  subject     String
  htmlContent String
  textContent String?
  variables   Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model MailLog {
  id           String        @id @default(cuid())
  toEmail      String
  subject      String
  templateKey  String?
  status       MailLogStatus @default(PENDING)
  errorMessage String?
  createdAt    DateTime      @default(now())

  @@index([templateKey])
  @@index([status])
  @@index([createdAt])
}

model ContactMessage {
  id        String               @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    ContactMessageStatus @default(NEW)
  adminNote String?
  repliedAt DateTime?
  source    String?
  formKey   String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

model FormDefinition {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  fields    Json     @default("[]")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions FormSubmission[]

  @@index([isActive])
}

model FormSubmission {
  id        String               @id @default(cuid())
  formId    String
  data      Json
  status    FormSubmissionStatus @default(NEW)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  form FormDefinition @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([status])
  @@index([createdAt])
}

model ProductReview {
  id         String              @id @default(cuid())
  productId  String
  customerId String?
  orderId    String?
  name       String
  email      String
  rating     Int
  title      String?
  comment    String
  status     ProductReviewStatus @default(PENDING)
  adminReply String?
  approvedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([status])
  @@index([email])
  @@index([createdAt])
}

model SeoSetting {
  id                  String   @id @default("default")
  defaultTitle        String   @default("")
  defaultDescription  String   @default("")
  defaultOgImageId    String?
  robotsTxt           String   @default("")
  googleAnalyticsId   String?
  metaPixelId         String?
  canonicalBaseUrl    String?
  sitemapIncludeProducts   Boolean @default(true)
  sitemapIncludeCategories Boolean @default(true)
  sitemapIncludePages      Boolean @default(true)
  sitemapIncludeBlogPosts  Boolean @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model RedirectRule {
  id         String   @id @default(cuid())
  sourcePath String   @unique
  targetPath String
  statusCode Int      @default(301)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
}

model Coupon {
  id                     String     @id @default(cuid())
  code                   String     @unique
  type                   CouponType
  value                  Decimal    @db.Decimal(12, 2)
  minOrderAmount         Decimal?   @db.Decimal(12, 2)
  usageLimit             Int?
  usageLimitPerCustomer  Int?
  startsAt               DateTime?
  endsAt                 DateTime?
  isActive               Boolean    @default(true)
  applicableProductIds   Json       @default("[]")
  applicableCategoryIds  Json       @default("[]")
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  carts  Cart[]
  orders Order[]

  @@index([isActive])
  @@index([code])
}

model Campaign {
  id            String       @id @default(cuid())
  name          String
  type          CampaignType
  bannerImageId String?
  title         String
  description   String?
  buttonText    String?
  buttonUrl     String?
  startsAt      DateTime?
  endsAt        DateTime?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([isActive])
  @@index([type])
}

model Notification {
  id         String           @id @default(cuid())
  type       NotificationType
  title      String
  message    String
  entityType String?
  entityId   String?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([isRead, createdAt(sort: Desc)])
  @@index([type])
}
