# API Environment Variables
# Copy to .env and fill in values

NODE_ENV=development
PORT=3001

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/woontegra_commerce?schema=public"

# JWT
JWT_SECRET=change-me-in-production-min-8-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Default tenant (single-tenant / demo mode)
DEFAULT_TENANT_SLUG=demo

# Storage: local | s3
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage/uploads
STORAGE_PUBLIC_BASE_URL=http://localhost:3001/media

# CORS
CORS_ORIGIN=http://localhost:5173
