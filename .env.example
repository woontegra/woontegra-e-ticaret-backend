# =============================================================================
# Woontegra Commerce API — Environment Variables
# Copy to .env and fill in values. See docs/ENVIRONMENT.md for details.
# =============================================================================

# --- Core ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# --- Database (required) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/woontegra_commerce?schema=public"

# --- Auth (required) ---
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Public URLs (production: required for SEO, media, CORS) ---
# Storefront origin (Vercel / custom domain)
PUBLIC_SITE_URL=https://magaza.example.com
# API public origin (Railway / custom domain) — used for /media URL fallback
API_PUBLIC_URL=https://api.example.com
# Comma-separated browser origins allowed for CORS (include PUBLIC_SITE_URL)
CORS_ORIGIN=http://localhost:5173,https://magaza.example.com

# --- Media storage ---
# local = dev fallback on disk served at /media
STORAGE_DRIVER=local
IMAGE_STORAGE_DRIVER=vercel_blob
DOWNLOAD_STORAGE_DRIVER=r2
# Development: relative path. Production default: /data/uploads (mount a volume)
STORAGE_LOCAL_PATH=./storage/uploads
UPLOAD_DIR=uploads
# Full URL prefix for local uploaded files (DB stores storageKey)
# If unset, derived as ${API_PUBLIC_URL}/media
STORAGE_PUBLIC_BASE_URL=http://localhost:3001/media
# Max upload sizes (bytes)
UPLOAD_MAX_IMAGE_BYTES=10485760
UPLOAD_MAX_DOWNLOAD_BYTES=524288000

# --- Vercel Blob (site images: logo, hero, products, blog, builder, campaigns) ---
BLOB_READ_WRITE_TOKEN=
VERCEL_BLOB_READ_WRITE_TOKEN=

# --- Cloudflare R2 (private download binaries: exe, zip, setup, portable) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_BUCKET_NAME=woontegra-media
R2_PRIVATE_BUCKET_NAME=woontegra-downloads
R2_PUBLIC_BASE_URL=
R2_DOWNLOADS_PUBLIC_BASE_URL=

# --- Digital download tokens ---
DOWNLOAD_TOKEN_SECRET=
DOWNLOAD_TOKEN_DAYS=90

# --- Mail (optional bootstrap — admin panel overrides when configured) ---
# Primary config: Admin → Ayarlar → Mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=
MAIL_REPLY_TO=
MAIL_ACTIVE=false

# --- Tenant ---
DEFAULT_TENANT_SLUG=demo

# --- Production checklist ---
# 1. NODE_ENV=production
# 2. Strong JWT_SECRET (openssl rand -hex 32)
# 3. PUBLIC_SITE_URL + API_PUBLIC_URL + CORS_ORIGIN
# 4. BLOB_READ_WRITE_TOKEN for CMS images
# 5. R2_* credentials for download binaries (private bucket)
# 6. Run: npx prisma migrate deploy && npm run db:seed (first deploy only)
